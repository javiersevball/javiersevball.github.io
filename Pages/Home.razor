        </MudItem>

        @* Contact Section *@
        <MudItem xs="12" Class="mt-10">
            <div class="pa-8 d-flex flex-column align-center" style="border: 2px dashed rgba(0, 242, 255, 0.2); background: rgba(0, 242, 255, 0.02); border-radius: 8px;">
                <MudText Typo="Typo.h6" Style="color: var(--mud-palette-primary); font-family: 'JetBrains Mono'; font-weight: 900; letter-spacing: 2px;">
                    > SYSTEM_INQUIRY
