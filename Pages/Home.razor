                    <br /><br />
                    Let's talk about software, leadership insights, or complex system architecture.
                </MudText>
                <MudButton Variant="Variant.Outlined" 
                        Color="Color.Primary" 
                        Size="Size.Large"
                        Href="https://www.linkedin.com/in/javiersevball/"
                        Target="_blank"
                        Style="font-family: 'JetBrains Mono'; font-weight: bold; border-width: 2px;">
                    SEND MESSAGE
                </MudButton>
            </div>
        </MudItem>

        @* Footer *@
        <MudItem xs="12" Class="mt-12 mb-6">
            <div class="d-flex justify-center align-center" style="opacity: 0.6; border-top: 1px dashed rgba(0, 242, 255, 0.1); padding-top: 24px;">
                <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono', monospace; letter-spacing: 1px; text-transform: uppercase;">
                    <span style="color: var(--mud-palette-primary); font-weight: bold;">></span> 
                    Made by 
                    <MudLink href="https://github.com/javiersevball" Target="_blank" Underline="Underline.None" 
