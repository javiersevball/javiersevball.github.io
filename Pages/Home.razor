                            <div class="d-flex align-center mt-2 flex-wrap gap-2">
                                <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" Class="pa-0" Style="font-weight: 900;">
                                    [ GRADE: DISTINCTION ]
                                </MudChip>
                                <MudLink href="https://ruidera.uclm.es/items/bbece58c-ac2c-4af3-a787-02327d24009f" Target="_blank" Underline="Underline.Hover" Style="color: var(--mud-palette-primary); font-family: 'JetBrains Mono'; font-size: 0.7rem; font-weight: bold;">
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;"/> VIEW_PROJECT
                                </MudLink>
                            </div>

