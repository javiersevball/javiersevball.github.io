@page "/"

<style>
    .skill-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: rgba(255, 255, 255);
        transition: all 0.2s ease;
        cursor: default;
        white-space: nowrap;
    }

    .skill-tag:hover {
        color: var(--mud-palette-primary);
        text-shadow: 0 0 8px rgba(0, 242, 255, 0.4);
    }
</style>

<PageTitle>Javier Sevilla | Software Development Lead</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 animate__animated animate__fadeIn">
    <MudGrid>
        @* Header / about me section *@
        <MudItem xs="12">
            <div class="pa-6" style="border-left: 3px solid var(--mud-palette-primary); background: rgba(0, 242, 255, 0.015); border-radius: 0 4px 4px 0;">
                @* Block header *@
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6" Style="font-weight: 800; text-transform: uppercase; color: var(--mud-palette-primary); letter-spacing: 2px;">
                        System Overview
                    </MudText>
                </div>

                @* Sector metadata *@
                <div class="mb-6">
                    <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono', monospace; letter-spacing: 1px; font-weight: 700;">
                        SECTOR: <span style="color: var(--mud-palette-secondary);">AEROSPACE & DEFENSE</span>
                    </MudText>
                </div>

                @* Main description *@
                <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; line-height: 1.6; opacity: 0.9;">
                    <span style="color: var(--mud-palette-primary); font-weight: bold;">></span> Hi there! I'm
                    <span style="color: var(--mud-palette-secondary); font-weight: bold;">Javier</span>, a Computer Engineering graduate
                    currently working at <span style="font-weight: bold;">TECNOBIT</span> as a <span style="border-bottom: 1px solid var(--mud-palette-primary);">Software Development Lead</span>.
                </MudText>

                @* Closing line*@
                <div class="mt-4 pt-4" style="border-top: 1px dashed rgba(0, 242, 255, 0.1);">
                    <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono', monospace; letter-spacing: 1px; font-weight: 700; opacity: 0.8;">
                        PROGRAMMING // CLEAN ARCHITECTURE // ROBUST & SCALABLE SYSTEMS // PIZZA
                    </MudText>
                </div>
            </div>
        </MudItem>

        @* Core capabilities section *@
        <MudItem xs="12" Class="mt-8">
            <div class="pa-6" style="border: 1px solid rgba(0, 242, 255, 0.1); background: rgba(0, 242, 255, 0.005); border-radius: 4px;">
                <MudText Typo="Typo.h6" Style="color: var(--mud-palette-primary); letter-spacing: 2px; font-weight: 900;">
                    CORE CAPABILITIES
                </MudText>

                <MudGrid Class="mt-4" Spacing="4">
                    @* Languages *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="opacity: 0.5; font-weight: bold; text-transform: uppercase;">Languages</MudText>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in new[] { "C#", "C++", "Python", "SQL" })
                            {
                                <div class="skill-tag">[ @item ]</div>
                            }
                        </div>
                    </MudItem>

                    @* Frameworks *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="opacity: 0.5; font-weight: bold; text-transform: uppercase;">Frameworks & UI</MudText>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in new[] { ".NET", ".NET Framework", "Avalonia", "Blazor", "ASP.NET", "Qt", "OpenCV"})
                            {
                                <div class="skill-tag">[ @item ]</div>
                            }
                        </div>
                    </MudItem>

                    @* Design and rchitecture *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="opacity: 0.5; font-weight: bold; text-transform: uppercase;">Design & Architecture</MudText>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in new[] { "Clean code", "Clean architecture", "UML" })
                            {
                                <div class="skill-tag">[ @item ]</div>
                            }
                        </div>
                    </MudItem>

                    @* Tools *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="opacity: 0.5; font-weight: bold; text-transform: uppercase;">DevOps & VCS</MudText>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in new[] { "Jenkins", "Git", "SVN" })
                            {
                                <div class="skill-tag">[ @item ]</div>
                            }
                        </div>
                    </MudItem>
                </MudGrid>
            </div>
        </MudItem>

        @* Professional experience section *@
        <MudItem xs="12" Class="mt-8">
            <div class="pa-6" style="border: 1px solid rgba(0, 242, 255, 0.1); background: rgba(0, 242, 255, 0.005); border-radius: 4px;">
                <MudText Typo="Typo.h6" Class="mb-6" Style="color: var(--mud-palette-primary); letter-spacing: 2px; font-weight: 900;">
                    PROFESSIONAL EXPERIENCE
