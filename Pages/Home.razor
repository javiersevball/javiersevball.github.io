                    <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Class="mr-3" />
                    <MudText Typo="Typo.h5" Style="font-weight: 800; letter-spacing: 1px;">TECNOBIT - GRUPO OESÍA</MudText>
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="ml-4" Style="font-family: 'JetBrains Mono'; opacity: 0.7;">@GetTotalExperience(2017, 3)</MudChip>
                </div>

                <div style="border-left: 2px solid rgba(0, 242, 255, 0.1); margin-left: 12px; padding-left: 30px;">
                    @* Rol: LEAD *@
                    <div class="mb-10" style="position: relative;">
                        <div style="position: absolute; left: -37px; top: 8px; width: 12px; height: 12px; border-radius: 50%; background: var(--mud-palette-primary); box-shadow: 0 0 10px var(--mud-palette-primary);"></div>
                        <div class="d-flex justify-space-between align-start flex-wrap">
                            <MudText Typo="Typo.subtitle1" Style="color: var(--mud-palette-secondary); font-weight: bold; text-transform: uppercase;">Software Development Lead | Test Engineering</MudText>
                            <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono'; opacity: 0.6;">[ OCT 2024 - PRESENT ]</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Class="mt-2" Style="font-family: 'JetBrains Mono'; opacity: 0.9; line-height: 1.5;">
                            Leading a team responsible for the end-to-end development of software for Automated Test Systems;
                            specializing in the aerospace and defense fields. Overseeing all phases of software engineering,
                            from requirements gathering and system architecture to coding, integration and validation.
                            Ensuring compliance with industry standards and integrating new methodologies to optimize test processes
                            and improve their performance, as well as enabling efficient production and maintenance processes.
                            <br /><br />
                            Mainly focused on delivering innovative solutions for testing automation in complex environments.
                        </MudText>
                    </div>

                    @* Rol: SW ENGINEER (TEST) *@
                    <div class="mb-10" style="position: relative;">
                        <div style="position: absolute; left: -37px; top: 8px; width: 12px; height: 12px; border-radius: 50%; background: rgba(0, 242, 255, 0.4);"></div>
                        <div class="d-flex justify-space-between align-start flex-wrap">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: bold; text-transform: uppercase;">Software Engineer | Test Engineering</MudText>
                            <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono'; opacity: 0.6;">[ NOV 2021 - SEPT 2024 ]</MudText>
                        </div>
                        <ul style="list-style: none; padding: 0; margin-top: 8px;">
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- SW Team Leadership.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Development of automatic test SW for new products in production.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Evolution and standarization of test SW used in production.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Implementation of new SW methodologies for Industry 4.0.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9;">-- Continuous integration of SW components.</li>
                        </ul>
                    </div>

                    @* Rol: SW ENGINEER (OPTRONICS) *@
                    <div class="mb-10" style="position: relative;">
                        <div style="position: absolute; left: -37px; top: 8px; width: 12px; height: 12px; border-radius: 50%; background: rgba(0, 242, 255, 0.2);"></div>
                        <div class="d-flex justify-space-between align-start flex-wrap">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: bold; text-transform: uppercase;">Software Engineer | Optronics</MudText>
                            <MudText Typo="Typo.caption" Style="font-family: 'JetBrains Mono'; opacity: 0.6;">[ FEB 2018 - OCT 2021 ]</MudText>
                        </div>
                        <ul style="list-style: none; padding: 0; margin-top: 8px;">
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Design, implementation, and integration of software components for Automated Test Equipment (ATE).</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Embedded software development.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9; margin-bottom: 4px;">-- Implementation and integration of automated test sequences for the verification and qualification of optronic systems.</li>
                            <li style="font-family: 'JetBrains Mono'; font-size: 0.85rem; opacity: 0.9;">-- Development and maintenance of applications for manual control of systems.</li>
