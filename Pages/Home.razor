            </div>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    /// <summary>
    /// Gets the total experience in years and months.
    /// </summary>
    /// <returns></returns>
    private string GetTotalExperience(int startYear, int startMonth)
    {
        DateTime startDate = new DateTime(startYear, startMonth, 1);
        DateTime endDate = DateTime.Now;

        int years = endDate.Year - startDate.Year;
        int months = endDate.Month - startDate.Month;

        if (months < 0)
        {
            years--;
            months += 12;
        }

        return $"{years} YEARS // {months} MONTHS";
    }
}
